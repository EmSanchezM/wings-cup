    "nuxt": "^4.4.4",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.7",
    "shadcn-nuxt": "^2.6.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.4.1",
