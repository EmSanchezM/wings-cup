# =============================================================================
# Wings Cup — environment variable contract
# Copy this file to .env.local and fill in the values.
# NEVER commit .env or .env.local — they are gitignored.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase connection (from Project Settings -> API in the Supabase dashboard)
# @nuxtjs/supabase v2 reads these directly. No runtimeConfig.public duplication.
# ---------------------------------------------------------------------------

# Public -- safe to expose in the client bundle (anon/public role only)
NUXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=eyJ...

# Server-only -- the service_role key bypasses RLS. NEVER expose this in the client.
# In Nuxt: maps to runtimeConfig.supabaseServiceKey (no NUXT_PUBLIC_ prefix = server-only).
NUXT_SUPABASE_SERVICE_KEY=eyJ...

# ---------------------------------------------------------------------------
# Cron secret -- server-only (slice 3 uses this)
# Vercel sends "Authorization: Bearer ${CRON_SECRET}" automatically when invoking cron routes.
# Generate a strong random string: openssl rand -hex 32
# ---------------------------------------------------------------------------
NUXT_CRON_SECRET=
